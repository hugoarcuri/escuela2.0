{
  "name": "gestion-calificaciones",
  "version": "1.0.0",
  "description": "Gestión de Calificaciones Escolares",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build:backend": "tsc",
    "build:frontend": "cd ../frontend && npx vite build",
    "build": "npm run build:backend && npm run build:frontend",
    "start": "node dist/index.js",
    "seed": "tsx src/seed.ts",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "electron:dev": "electron .",
    "electron:build": "npm run build && electron-builder",
    "electron:start": "electron ."
  },
  "build": {
    "appId": "com.escuela.gestion-calificaciones",
    "productName": "Gestión de Calificaciones",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "prisma/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../frontend/dist",
        "to": "frontend/dist"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "cors": "^2.8.6",
    "exceljs": "^4.4.0",
    "express": "^4.22.2",
    "multer": "^2.1.1",
    "pdfkit": "^0.19.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.3",
    "@types/pdfkit": "^0.17.6",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
